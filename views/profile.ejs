<!DOCTYPE html>
<html lang="en">
   <head>
      <script src="https://code.jquery.com/jquery-3.3.1.min.js"></script>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.min.js" integrity="sha384-QJHtvGhmr9XOIpI6YVutG+2QOK9T+ZnN4kzFN1RtK3zEFEIsxhlmWl5/YESvpZ13" crossorigin="anonymous"></script>
      <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.3.0/css/all.min.css" integrity="sha512-SzlrxWUlpfuzQ+pcUCosxcglQRNAq/DZjVsC0lE40xsADsfeQoEypE+enwcOiGjk/bSuGGKHEyjSoQ1zVisanQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/shards-ui@3.0.0/dist/css/shards.min.css">
      <script src="https://cdn.jsdelivr.net/npm/shards-ui@3.0.0/dist/js/shards.min.js"></script>
      <link href="https://fonts.googleapis.com/css2?family=Roboto+Slab&display=swap" rel="stylesheet">
      <link rel="stylesheet" href="/css/styles.css">
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title> <%= user.full_name %> (@<%= user.username %>) - Profile</title>
      <meta property="og:title" content="<%= user.full_name %> (@<%= user.username %>) - Profile">
      <meta property="og:description" content="View the profile of <%= user.full_name %> (@<%= user.username %>) on our site.">
      <meta property="og:url" content="https://demo.truanon.com/users/<%= user.username %>">
      <meta name="twitter:title" content="<%= user.full_name %> (@<%= user.username %>) - Profile">
      <meta name="twitter:description" content="View the profile of <%= user.full_name %> (@<%= user.username %>) on our site.">
<meta property="og:image" content="<%= user.authorPhoto && user.switch_state === 'on' ? user.authorPhoto : user.photo %>">
<meta name="twitter:image" content="<%= user.authorPhoto && user.switch_state === 'on' ? user.authorPhoto : user.photo %>">
      <meta name="twitter:card" content="summary_large_image">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=IBM+Plex+Mono:wght@400;700&family=Space+Grotesk:wght@400;700&family=Work+Sans:wght@400;600&family=Barlow:wght@400;600&display=swap" rel="stylesheet">
   </head>
   <body>
      <%- include('header', { currentPage: 'Member Profile' }) %> <!-- Include your header -->
       
       <style>
         .custom-border-4 {
            border-width: 10.25px !important;
         }
         .containerDiv ul {
            padding: 1rem;
         }
       </style>
      <div class="container-xxl my-md-4 bd-layout" >
         <div id="containerDiv">
            <div class="container-xxl my-md-4 bd-layout">
               <div class="row gutters-sm">
                  <div class="col-md-4 mb-3 ">
                     <div class="card">
                        <div class="card-body">
                           <div class="align-items-center text-center ">
                              <img id="photo" src="https://bootdey.com/img/Content/avatar/avatar7.png" alt="Admin" class="rounded-circle border custom-border-4" width="150">
                              <div class="mt-3 ">
                                 <h4 id="fullname">John Doe</h4>
                                 <p id="username" class="text-secondary mb-1">Full Stack Developer</p>
                                 <p id="location" class="text-muted font-size-sm">Bay Area, San Francisco, CA</p>
                                 <div   class="pb-3 ">
                                   <button class="btn btn-primary ">Follow</button>
                                   <button class="btn btn-outline-primary">Message</button>
                                  </div>
                                 <div id="badge-area"></div>
                              </div>
                           </div>
                        </div>
                     </div>
                  </div>
                  <div id="personal-space" class="col-md-8"> 
                     <div id="new-slot" class="card mb-3"></div>
                  </div>
               </div>
            </div>
         </div>
      </div>



      <script>
         var verifiedDetails = {};
         var containerDivOld = $('#containerDiv');
         
         
         
         function getPhotoBorderColor(authorRank) {
         switch (authorRank) {
         case 'Dangerous':
         return 'danger';
         case 'Cautioned':
         return 'warning';
         case 'Credible':
         return 'secondary';
         case 'Reliable':
         return 'success';
         case 'Genuine':
         return 'primary';
         case 'Unknown':
         return 'secondary';
         default:
         return 'secondary';
         }
         }
         
         // if a user switch_state is true
         // the author verifiedDetails.authorRank will show one of five levels
        // Dangerous, Cautioned, Credible, Reliable and Genuine
         // we want bootstrap colors danger, warning, secondary, success and primary to relate to each state
         // we want a short javascript function that returns the css class to be added to rounded-circle
         // in order to set the color of this user's photo border to their proper color


      // Select the photo element
      var photo = $('#photo');

      // Default user photo
        var defaultPhoto = '<%= user.authorPhoto && user.switch_state === "on" ? user.authorPhoto : user.photo %>';


        photo.attr('src', defaultPhoto);
         photo.attr('alt', 'Profile photo');
         photo.attr('max-width', '280');
         
         //containerDivOld.append(photo);
         
         const name = $('#fullname');
         name.text('<%= user.full_name %>');
         
         const name2 = $('#fullname2');
         name2.text('<%= user.full_name %>');
         
         const username = $('#username');
         username.text('@<%= user.username %> ');
         
         const ulocation = $('#location');
         ulocation.text('<%= user.location %>');
         
         const address2 = $('#address2');
         address2.text('<%= user.location %>');
         
         
         function filterDataConfigurations(myData, dataPointType, dataPointKind) {
         // Return an empty array if myData is empty or myData.dataConfigurations is not defined
         if (!myData || !myData.dataConfigurations) {
         return [];
         }
         
         // Use the filter() method to filter the objects from myData.dataConfigurations
         // that match the specified dataPointType and dataPointKind.
         var filteredData = myData.dataConfigurations.filter(function(config) {
         if (dataPointType.length) {
         return config.dataPointType === dataPointType && config.dataPointKind === dataPointKind;
         }
         return config.dataPointKind === dataPointKind;
         });
         
         return filteredData;
         }
         
         var badge = document.createElement("span");
         badge.className = "w-100 btn disabled btn-outline-secondary mb-4";
         
         var badgeLogo = document.createElement("span");
         badgeLogo.className = "fas fa-check-circle fa-5x align-middle p-2";
         badge.appendChild(badgeLogo);
         
         var badgeRank = document.createElement("div");
         badgeRank.className = "badge-rank text-muted h3";
         badgeRank.innerText = "Unknown";
         badge.appendChild(badgeRank);
         
         var badgeScore = document.createElement("div");
         badgeScore.className = "badge-score text-muted h5";
         badgeScore.innerText = "Ask This Member To Verify Their Identity";
         badge.appendChild(badgeScore);
         
         //containerDivOld.append(badge);
         $('#badge-area').html(badge);
         
      </script>

      <script>
          // Fetch processed display data
          <% 
              var displayData = getUserDisplayData(user); 
          %>

          var photo = $('#photo');

      </script>

      <% if (user.switch_state) { %>
<script>
(function() {
    var makePrivate = !!<%= user.make_private || 0 %>;
    var showSocial   = !!(<%- (user.show_social   === undefined || user.show_social   !== 0) ? 1 : 0 %>);
    var showPersonal = !!(<%- (user.show_personal === undefined || user.show_personal !== 0) ? 1 : 0 %>);

    // Show spinner in badge area while TruAnon loads
    document.getElementById('badge-area').innerHTML =
        '<div class="text-center text-muted p-3"><i class="fas fa-spinner fa-spin fa-2x"></i></div>';

    fetch('/users/<%= user.username %>/truanon')
        .then(function(r) { return r.ok ? r.json() : Promise.reject('unavailable'); })
        .then(function(verifiedDetails) {

            // === MAIN BADGE ===
            $('#location').text(verifiedDetails.authorTitle);

            var badge = makePrivate ? document.createElement("span") : document.createElement("a");
            badge.className = "w-100 btn mb-4 btn-outline-" + getPhotoBorderColor(verifiedDetails.authorRank);
            if (!makePrivate) {
                var truanonConfigs = filterDataConfigurations(verifiedDetails, "truanon", "social");
                if (truanonConfigs.length) { badge.href = "https://" + truanonConfigs[0].displayValue; badge.target = "_blank"; }
            }
            var badgeLogo = document.createElement("span");
            badgeLogo.className = "fas fa-check-circle fa-5x align-middle p-2";
            badge.appendChild(badgeLogo);
            var badgeRank = document.createElement("div");
            badgeRank.className = "badge-rank h3";
            badgeRank.innerText = verifiedDetails.authorRank;
            badge.appendChild(badgeRank);
            var badgeScore = document.createElement("div");
            badgeScore.className = "badge-score h5";
            badgeScore.innerHTML = "(" + verifiedDetails.authorRankScore + " of 5)<p class=\"pt-4\"><b>" +
                (verifiedDetails.authorAgeBadge ? " ⸻ " + verifiedDetails.authorAgeBadge + " ⸻ " : "") + "</b></p>";
            badge.appendChild(badgeScore);
            $('#badge-area').html(badge);

            // === SOCIAL PROFILES ===
            var dataConfigurationsList = document.createElement("ul");
            var filteredSocial = filterDataConfigurations(verifiedDetails, "", "social");
            var truanonOnly    = filterDataConfigurations(verifiedDetails, "truanon", "social");
            var filteredDataMinusTruanon = filteredSocial.filter(function(c) { return !truanonOnly.includes(c); });
            var socialHTML = createDataConfigurationsList(filteredDataMinusTruanon, dataConfigurationsList);
            if (showSocial) document.body.appendChild(socialHTML);

            // === CONTACT / PERSONAL ===
            var filteredContact = filterDataConfigurations(verifiedDetails, "", "contact")
                .concat(filterDataConfigurations(verifiedDetails, "location", "personal"))
                .concat(filterDataConfigurations(verifiedDetails, "", "primary"))
                .concat(filterDataConfigurations(verifiedDetails, "", "additional"));
            var contactHTML = createContactList(filteredContact);
            if (showPersonal) $('#personal-space').prepend(contactHTML);

            // === VERIFIED PROPERTIES SLOT ===
            var newSlot = document.getElementById("new-slot");
            newSlot.innerHTML = '';
            var slotHeader = document.createElement("div");
            slotHeader.classList.add("card-header", "text-center", "h5", "text-secondary");
            slotHeader.innerText = "Verified Properties";
            newSlot.appendChild(slotHeader);
            if (showSocial) newSlot.appendChild(dataConfigurationsList);

            // === GITHUB BADGE (after TruAnon data is available) ===
            var githubConfig = (verifiedDetails.dataConfigurations || []).find(function(c) {
                return c.dataPointType === "github";
            });
            loadGithubBadge(githubConfig);
        })
        .catch(function(err) {
            console.log('TruAnon data unavailable:', err);
            document.getElementById('badge-area').innerHTML = ''; // restore default Unknown badge
        });

    function loadGithubBadge(githubConfig) {
        var badgeArea = document.getElementById("badge-area");
        var icon = document.createElement("span");
        var title = document.createElement("h5");
        var description = document.createElement("p");
        var githubBadge = document.createElement("div");

        icon.className = "text-warning fas fa-ban fa-10x mb-2 pt-2";
        title.innerText = "Engineering Badge Unavailable";
        description.innerHTML = "No Validating Credentials Provided<hr><div class='text-secondary'>Trusted Sources Are: Bitbucket, GitLab, SourceForge, Codeberg, and GitHub</div>";
        githubBadge.classList.add("card", "text-center", "p-3", "m-3", "border-warning");
        title.classList.add("card-title", "text-dark", "mb-1", "pt-4");
        description.classList.add("card-text", "text-muted");
        githubBadge.append(icon, title, description);

        if (!githubConfig || githubConfig.displayValue.startsWith("Privately Verified")) {
            badgeArea.insertAdjacentElement("afterend", githubBadge);
            return;
        }

        var loadingPlaceholder = document.createElement("div");
        loadingPlaceholder.classList.add("text-center", "p-3", "m-3", "text-muted");
        loadingPlaceholder.innerHTML = '<div><div class="fas fa-spinner fa-spin fa-2x mb-4 mt-4"></div></div>';
        badgeArea.insertAdjacentElement("afterend", loadingPlaceholder);

        fetch('/users/<%= user.username %>/github')
            .then(function(r) { if (!r.ok) throw new Error("not ok"); return r.json(); })
            .then(function(data) {
                loadingPlaceholder.remove();
                var githubUsername = data.fullName || "No Name Provided";
                var githubRepos    = data.totalRepos;
                var githubCreated  = data.githubCreated || "Unknown";
                var githubAge      = data.githubAge || "";
                var failureReasons = [];
                var badgeColor = githubRepos > 0 ? "success" : "danger";
                if (badgeColor !== "success") failureReasons.push("No Repos");
                if (githubAge.includes("0 years") && parseInt(githubAge.split(",")[1]) < 2) failureReasons.push("Not 60 Days Old");
                if (failureReasons.length) badgeColor = "danger";

                githubBadge.classList.add("text-" + badgeColor, "border-" + badgeColor);
                icon.className = "fas fa-" + (badgeColor === "success" ? "award" : "frown") + " fa-10x mb-2 pt-2";
                title.className = "card-title text-" + badgeColor + " mb-1 pt-4";
                title.innerHTML = githubUsername + "<br>" + githubRepos + " Repos";
                description.className = "card-title text-" + badgeColor + " mb-1 pt-4";
                description.innerHTML = (failureReasons.length ? "<b>Provided Credentials Do Not Suffice</b>" : "Engineer Status Validated") +
                    "<br><small class='text-muted'> " + githubCreated + " " + githubAge + "</small>";

                var allLanguages = Array.isArray(data.repos) ? data.repos.flatMap(function(r) {
                    return r.languages ? r.languages.split(", ").filter(Boolean) : [];
                }) : [];
                var uniqueLanguages = allLanguages.length ? [...new Set(allLanguages)] : ["No Computer Languages Detected"];
                var repoList = document.createElement("div");
                repoList.innerHTML = "<span class='text-muted small fst-italic'>" + uniqueLanguages.join(", ") + "</span>" +
                    "<div><br><hr><br><p>this authoritative information has been validated at the source and securely transferred to ensure trusted use</p></div>" +
                    "<div class='text-secondary'>Trusted Sources Are: Bitbucket, GitLab, SourceForge, Codeberg, and GitHub</div>";
                githubBadge.appendChild(repoList);
                badgeArea.insertAdjacentElement("afterend", githubBadge);
            })
            .catch(function(err) {
                console.error("Error fetching GitHub data:", err);
                loadingPlaceholder.innerHTML = '<div><i class="fas fa-exclamation-circle fa-4x text-danger"></i><p>Failed to load GitHub data.</p></div>';
            });
    }

    function createContactList(filteredData) {
        var list = document.createElement("div");
        list.classList.add("card", "mb-3");
        var header = document.createElement("div");
        header.classList.add("card-header", "text-center", "h5", "text-secondary");
        header.innerText = "Contact Information";
        list.appendChild(header);
        var cardBody = document.createElement("div");
        cardBody.classList.add("card-body");
        list.appendChild(cardBody);
        filteredData.forEach(function(dataConfig, index) {
            var row = document.createElement("div");
            row.classList.add("row");
            cardBody.appendChild(row);
            var col1 = document.createElement("div");
            col1.classList.add("col-sm-3");
            var titleHeader = document.createElement("h6");
            titleHeader.classList.add("mb-0");
            titleHeader.innerText = dataConfig.dataPointName;
            col1.appendChild(titleHeader);
            row.appendChild(col1);
            var col2 = document.createElement("div");
            col2.classList.add("col-sm-9", "text-secondary");
            col2.innerText = dataConfig.displayValue;
            row.appendChild(col2);
            if (index < filteredData.length - 1) cardBody.appendChild(document.createElement("hr"));
        });
        return list;
    }

    function createDataConfigurationsList(filteredData, dataConfigurationsList) {
        dataConfigurationsList.classList.add("d-flex", "flex-wrap", "text-center");
        var display = filteredData.filter(function(c) {
            return c.dataPointType !== "github" && c.dataPointType !== "trusted";
        });
        display.forEach(function(dataConfig) {
            var item = document.createElement("div");
            item.classList.add("text-secondary", "p-2", "m-1");
            item.style.textAlign = "center";
            var link = document.createElement("a");
            if (makePrivate || dataConfig.displayValue.includes("Privately")) {
                link.style.pointerEvents = "none";
                link.style.color = "gray";
            } else {
                try {
                    new URL("https://" + dataConfig.displayValue);
                    link.href = "https://" + dataConfig.displayValue;
                    link.target = "_blank";
                } catch(e) {
                    link.style.pointerEvents = "none";
                    link.style.color = "gray";
                }
            }
            var iconSpan = document.createElement("span");
            iconSpan.className = dataConfig.dataPointIconClass + " fa-5x mb-1";
            link.appendChild(iconSpan);
            var titleDiv = document.createElement("div");
            titleDiv.style.textAlign = "center";
            titleDiv.style.width = "92px";
            var titleSpan = document.createElement("div");
            titleSpan.innerText = dataConfig.dataPointName;
            titleSpan.classList.add("title-span");
            titleSpan.style.textAlign = "center";
            titleDiv.appendChild(titleSpan);
            item.appendChild(link);
            item.appendChild(titleDiv);
            dataConfigurationsList.appendChild(item);
        });
        return dataConfigurationsList;
    }
})();
</script>
      <% } %>


<script>
    photo.attr('src', "<%= displayData.photo %>");
    photo.attr('class', 'rounded-circle border custom-border-4 border-' + "<%= displayData.borderColor %>");
</script>


      <%- include('footer') %>
   </body>
</html>