<!DOCTYPE html>
<html lang="en">
   <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <script src="https://code.jquery.com/jquery-3.3.1.min.js"></script>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.min.js" integrity="sha384-QJHtvGhmr9XOIpI6YVutG+2QOK9T+ZnN4kzFN1RtK3zEFEIsxhlmWl5/YESvpZ13" crossorigin="anonymous"></script>
      <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/shards-ui@3.0.0/dist/css/shards.min.css">
      <script src="https://cdn.jsdelivr.net/npm/shards-ui@3.0.0/dist/js/shards.min.js"></script>
      <link rel="stylesheet" href="/css/styles.css">
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.3.0/css/all.min.css" integrity="sha512-SzlrxWUlpfuzQ+pcUCosxcglQRNAq/DZjVsC0lE40xsADsfeQoEypE+enwcOiGjk/bSuGGKHEyjSoQ1zVisanQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />
      <title><%= user.username %> - Edit Profile</title>
      <link rel="icon" type="image/x-icon" href="https://truanon.s3.amazonaws.com/img/dogsquare.ico">
      <link rel="icon" type="image/png" sizes="16x16" href="https://truanon.s3.amazonaws.com/img/dogsquare.ico">
      <link rel="icon" type="image/png" sizes="32x32" href="https://truanon.s3.amazonaws.com/img/dogsquare.ico">
      <link rel="icon" type="image/png" sizes="64x64" href="https://truanon.s3.amazonaws.com/img/dogsquare.ico">
      <link rel="icon" type="image/png" sizes="128x128" href="https://truanon.s3.amazonaws.com/img/dogsquare.ico">
      <link rel="icon" type="image/png" sizes="256x256" href="https://truanon.s3.amazonaws.com/img/dogsquare.ico">
      <script src="https://gitcdn.github.io/bootstrap-toggle/2.2.2/js/bootstrap-toggle.min.js"></script>
      <link href="https://gitcdn.github.io/bootstrap-toggle/2.2.2/css/bootstrap-toggle.min.css" rel="stylesheet">
      <style>
         .form-switch .form-check-input {
            height: 2.0rem;
            width: 4.8rem;
         }
         .form-label {
            padding-top: 1rem;
         }
      </style>
   </head>
   <body>
      <link href="https://fonts.googleapis.com/css2?family=Roboto+Slab&display=swap" rel="stylesheet">
      <%- include('header', { currentPage: 'Edit' }) %>
      <div class="container-xxl my-md-4 bd-layout">
         <div class="container">
            <div class="row justify-content-center mt-5">
               <div class="col-md-6">
                  <div class="card">
                     <div class="card-header">
                        <h1 class="text-center">Edit Profile</h1>
                     </div>
                     <div class="card-body">
                        <form id="edit-form" method="POST" action="/users/<%= user.username %>/edit">

                           <div class="form-group">
                              <label for="full_name-input" class="form-label">Name:</label>
                              <input type="text" name="full_name" id="full_name-input" value="<%= user.full_name %>" class="form-control" />
                           </div>

                           <div class="form-group">
                              <label for="location-input" class="form-label">Location:</label>
                              <input type="text" name="location" id="location-input" value="<%= user.location %>" class="form-control" />
                           </div>

                           <div class="form-group">
                              <label class="form-label">Trusted Owner:</label>
                              <div class="input-group" id="owner-status"></div>
                           </div>

                           <!-- Switches — hidden until async confirms anchored; pitch shown until then -->
                           <div id="privacy-controls" style="display:none">
                           <div class="form-group">
                              <label for="verified-switch" class="form-label">Credibility Confidence:</label>
                              <div class="switch-container form-switch form-switch-pill p-0">
                                 <div class="border rounded px-3 d-flex align-items-center justify-content-between" style="background-color: #f8f9fa; padding:0.4em">
                                    <span class="text-muted">Use Identity Presence</span>
                                    <input class="form-check-input m-0" type="checkbox" name="switch_state" id="verified-switch"
                                           disabled
                                           <% if (user.switch_state === "on") { %>checked<% } %> />
                                 </div>
                              </div>
                           </div>

                           <div class="form-group">
                              <div class="switch-container form-switch form-switch-pill p-0">
                              <label for="verified-switch" class="form-label">Amplify:</label>
                                 <div class="border rounded px-3 d-flex align-items-center justify-content-between" style="background-color: #f8f9fa; padding:0.4em">
                                    <span class="text-muted">Present Personal Info</span>
                                    <input class="form-check-input m-0" type="checkbox" name="show_personal" id="show-personal-switch"
                                           disabled
                                           <% if (user.show_personal !== 0) { %>checked<% } %> />
                                 </div>
                              </div>
                           </div>

                           <div class="form-group">
                              <div class="switch-container form-switch form-switch-pill p-0">
                                 <div class="border rounded px-3 d-flex align-items-center justify-content-between" style="background-color: #f8f9fa; padding:0.4em">
                                    <span class="text-muted">Display Contact Details</span>
                                    <input class="form-check-input m-0" type="checkbox" name="show_contact" id="show-contact-switch"
                                           disabled
                                           <% if (user.show_contact !== 0) { %>checked<% } %> />
                                 </div>
                              </div>
                           </div>

                           <div class="form-group">
                              <div class="switch-container form-switch form-switch-pill p-0">
                                 <div class="border rounded px-3 d-flex align-items-center justify-content-between" style="background-color: #f8f9fa; padding:0.4em">
                                    <span class="text-muted">Showcase Social Confidence</span>
                                    <input class="form-check-input m-0" type="checkbox" name="show_social" id="show-social-switch"
                                           disabled
                                           <% if (user.show_social !== 0) { %>checked<% } %> />
                                 </div>
                              </div>
                           </div>

                           <div class="form-group">
                              <label for="make-private-switch" class="form-label">Protection:</label>
                              <div class="switch-container form-switch form-switch-pill p-0">
                                 <div class="border rounded px-3 d-flex align-items-center justify-content-between" style="background-color: #f8f9fa; padding:0.4em">
                                    <span class="text-muted">Make Private (no links)</span>
                                    <input class="form-check-input m-0" type="checkbox" name="make_private" id="make-private-switch"
                                           disabled
                                           <% if (user.make_private == 1) { %>checked<% } %> />
                                 </div>
                              </div>
                           </div>

                           </div><!-- /privacy-controls -->

                           <div id="identity-pitch" class="pt-4 p-1">
                              <h5>Verified Identity Will Boost Your Profile</h5>
                              <ul>
                                 <li>Show the history of expertise you want others to know you by.</li>
                                 <li>Protect yourself against impersonation.</li>
                                 <li>Gain trust and respect from the community.</li>
                                 <li>Be immediately recognized as an influencer and authority.</li>
                                 <li>Get more followers and more visibility.</li>
                              </ul>
                              <p>A verification badge signals that you are real, credible, authentic, and of interest to other members. It means that you are worthy of respect and understanding. It means that you care.</p>
                           </div>

                        </form>
                     </div>
                     <div class="card-footer text-center">
                        <button class="btn btn-primary" type="submit" form="edit-form">Save Changes</button>
                     </div>
                  </div>
               </div>
            </div>
         </div>
      </div>

      <!-- Bootstrap modal hosting TruAnon's verification UI -->
      <div class="modal fade" id="verificationModal" tabindex="-1" aria-labelledby="verificationModalLabel" aria-hidden="true">
         <div class="modal-dialog modal-dialog-centered" style="max-width: 480px;">
            <div class="modal-content">
               <div class="modal-header">
                  <h5 class="modal-title" id="verificationModalLabel">Verify Profile</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
               </div>
               <div class="modal-body" style="height: 840px; padding: 0;">
                  <iframe id="verificationIframe" src="" frameborder="0" style="width: 100%; height: 100%;"></iframe>
               </div>
            </div>
         </div>
      </div>

      <script>
         const username = '<%= user.username %>';
         const ownerEl = document.getElementById('owner-status');
         const identitySwitch = document.getElementById('verified-switch');
         const dependentSwitches = [
            document.getElementById('show-personal-switch'),
            document.getElementById('show-contact-switch'),
            document.getElementById('show-social-switch'),
            document.getElementById('make-private-switch'),
         ];

         function syncDependents() {
            const enabled = identitySwitch.checked && !identitySwitch.disabled;
            dependentSwitches.forEach(sw => { sw.disabled = !enabled; });
         }

         identitySwitch.addEventListener('change', syncDependents);

         // is_anchored is a DB fact — known immediately, no TruAnon call needed to determine state
         const isAnchored = !!<%= user.is_anchored %>;

         (function renderOwnerSection() {
            const input = document.createElement('input');
            input.type = 'text';
            input.className = 'form-control text-muted';
            input.readOnly = true;

            if (isAnchored) {
               input.value = 'Securely Assigned';
               ownerEl.replaceChildren(input);
               identitySwitch.disabled = false;
               syncDependents();
               document.getElementById('privacy-controls').style.display = '';
               document.getElementById('identity-pitch').style.display = 'none';

               // Fetch profileLink in background — not needed to render, just adds the view button
               fetch(`/users/${username}/edit-status`)
                  .then(r => r.json())
                  .then(data => {
                     if (data.profileLink) {
                        const link = document.createElement('a');
                        link.className = 'btn btn-primary rounded-end';
                        link.href = 'https://' + data.profileLink;
                        link.target = '_blank';
                        link.textContent = data.profileLink;
                        ownerEl.appendChild(link);
                     }
                  })
                  .catch(() => {});

            } else {
               input.value = 'Securely Assign Ownership';
               const btn = document.createElement('a');
               btn.href = '#';
               btn.className = 'btn btn-primary';
               btn.textContent = 'Verify';
               btn.addEventListener('click', async (e) => {
                  e.preventDefault();
                  btn.textContent = '…';
                  btn.classList.add('disabled');
                  try {
                     const res = await fetch(`/users/${username}/edit-status`);
                     const data = await res.json();
                     if (data.verifyUrl) openVerificationPopup(data.verifyUrl);
                  } catch (_) {}
                  btn.textContent = 'Verify';
                  btn.classList.remove('disabled');
               });
               ownerEl.replaceChildren(input, btn);
            }
         })();

         // Verification modal / polling logic
         let pollTimer = null;

         function startVerificationPolling() {
            pollTimer = setInterval(async () => {
               try {
                  const res = await fetch(`/users/${username}/truanon`);
                  const data = await res.json();
                  if (data && data.authorRank && data.authorRank !== 'Unknown') {
                     clearInterval(pollTimer);
                     bootstrap.Modal.getInstance(document.getElementById('verificationModal')).hide();
                     window.location.reload();
                  }
               } catch (e) { /* keep polling */ }
            }, 3000);
         }

         function stopPolling() {
            if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
         }

         window.addEventListener('message', (event) => {
            const action = event.data && event.data.action;
            if (action === 'closeVerificationModal' || action === 'verificationComplete') {
               stopPolling();
               bootstrap.Modal.getInstance(document.getElementById('verificationModal')).hide();
               window.location.reload();
            }
         });

         function openVerificationPopup(url) {
            document.getElementById('verificationIframe').src = url;
            const modal = new bootstrap.Modal(document.getElementById('verificationModal'));
            modal.show();
            startVerificationPolling();
            document.getElementById('verificationModal').addEventListener('hidden.bs.modal', () => {
               stopPolling();
               window.location.reload();
            }, { once: true });
         }
      </script>

      <%- include('footer') %>
   </body>
</html>
